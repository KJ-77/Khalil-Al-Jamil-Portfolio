# EmailJS — client-side contact form (Vite inlines VITE_* into the browser bundle)
# Copy this file to `.env.local` and fill in real values from your EmailJS dashboard.
# These are public values (safe to ship), but lock the public key to your domain
# in EmailJS dashboard → Account → Security → "Allow EmailJS API for these domains".
#
# Find them at:
#   SERVICE_ID  → Email Services → your service → Service ID
#   TEMPLATE_ID → Email Templates → your template → Template ID
#   PUBLIC_KEY  → Account → General → Public Key

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
